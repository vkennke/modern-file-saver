{
    "name": "modern-file-saver",
    "version": "3.0.0",
    "description": "Modern file saving library for browsers with File System Access API support and fallback",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./min": {
            "types": "./dist/index.d.ts",
            "import": "./dist/min/index.mjs",
            "require": "./dist/min/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "!dist/**/*.map",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsdown",
        "changeset": "changeset",
        "changeset:version": "changeset version && pnpm install --lockfile-only",
        "changeset:publish": "pnpm run build && changeset publish",
        "format": "prettier --write \"**/*.{js,ts,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
        "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && eslint src test",
        "lint:fix": "eslint src test --fix",
        "prepublishOnly": "pnpm run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "file",
        "save",
        "download",
        "browser",
        "file system access api",
        "blob",
        "base64",
        "file-saver",
        "filesaver",
        "saveAs",
        "file-download",
        "file-saver alternative",
        "file-saver replacement"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vkennke/modern-file-saver.git"
    },
    "author": "Valentin Kennke",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/vkennke/modern-file-saver/issues"
    },
    "homepage": "https://github.com/vkennke/modern-file-saver#readme",
    "devDependencies": {
        "@changesets/changelog-github": "^0.7.0",
        "@changesets/cli": "^2.31.0",
        "@eslint/js": "^10.0.1",
        "@types/wicg-file-system-access": "^2023.10.7",
        "@vitest/browser": "^4.1.9",
        "@vitest/browser-playwright": "^4.1.9",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^10.5.0",
        "playwright": "^1.61.0",
        "prettier": "3.8.4",
        "tsdown": "^0.22.2",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.61.1",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=20"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": "^22.18.0 || >=24.0.0",
            "onFail": "error"
        }
    },
    "browserslist": [
        "defaults"
    ],
    "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
