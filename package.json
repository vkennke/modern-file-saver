{
    "name": "modern-file-saver",
    "version": "2.0.0-rc.1",
    "description": "Modern file saving library for browsers with File System Access API support and fallback",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./min": {
            "types": "./dist/index.d.ts",
            "import": "./dist/min/index.mjs",
            "require": "./dist/min/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "!dist/**/*.map"
    ],
    "scripts": {
        "build": "tsup --config tsup.config.ts",
        "format": "prettier --write \"**/*.{js,ts,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
        "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
        "prepublishOnly": "npm run build",
        "test": "karma start --single-run",
        "test:watch": "karma start",
        "test:chrome": "karma start --browsers ChromeHeadless --single-run",
        "test:firefox": "karma start --browsers FirefoxHeadless --single-run"
    },
    "keywords": [
        "file",
        "save",
        "download",
        "browser",
        "file system access api",
        "blob",
        "base64"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/vkennke/modern-file-saver.git"
    },
    "author": "Valentin Kennke",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/vkennke/modern-file-saver/issues"
    },
    "homepage": "https://github.com/vkennke/modern-file-saver#readme",
    "devDependencies": {
        "@swc/core": "^1.15.40",
        "@types/jasmine": "^6.0.0",
        "@types/wicg-file-system-access": "^2023.10.7",
        "jasmine-core": "^6.2.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-firefox-launcher": "^2.1.3",
        "karma-jasmine": "^5.1.0",
        "karma-webpack": "^5.0.1",
        "prettier": "3.8.3",
        "ts-loader": "^9.5.7",
        "tsup": "^8.5.1",
        "typescript": "~5.9.3",
        "webpack": "^5.107.2"
    },
    "engines": {
        "node": ">=20"
    },
    "browserslist": [
        "defaults"
    ]
}
