#!/usr/bin/env sh
# Lockfile sync guard: if package.json is staged, make sure package-lock.json
# is up-to-date with it. If not, abort the commit with an actionable message
# instead of silently amending the user's commit.
#
# Rationale: we have repeatedly committed package.json edits without the
# corresponding package-lock.json update, which then breaks `npm ci` in CI.
# This hook catches that locally, before the push.

if ! git diff --cached --name-only | grep -qx 'package.json'; then
  exit 0
fi

# Warn (but don't block) if the local npm major version differs from the one
# CI uses to regenerate the lockfile (npm 11, see .github/workflows/ci.yml).
# Different npm majors produce slightly different lockfiles (dedupe, "peer"
# markers, optional emnapi deps, …), which would make CI's lockfile-sync
# check fail even though everything works locally.
NPM_MAJOR=$(npm --version | cut -d. -f1)
if [ "$NPM_MAJOR" != "11" ]; then
  echo "⚠️  [pre-commit] Local npm v$(npm --version) detected, but CI uses npm v11."
  echo "    Lockfile may differ from what CI generates. If CI's lockfile-sync"
  echo "    job fails, run 'npm install -g npm@11' and retry the commit."
fi

echo "[pre-commit] package.json is staged — verifying package-lock.json is in sync…"

# Regenerate the lockfile from package.json without touching node_modules.
# --ignore-scripts: don't run install hooks; --no-audit/--no-fund: less noise.
if ! npm install --package-lock-only --ignore-scripts --no-audit --no-fund >/dev/null 2>&1; then
  echo "::error::npm install --package-lock-only failed. Fix the error above and retry."
  exit 1
fi

if ! git diff --quiet -- package-lock.json; then
  echo ""
  echo "❌ package-lock.json is out of sync with package.json."
  echo ""
  echo "   It has been regenerated for you. Review the changes, then:"
  echo "     git add package-lock.json"
  echo "     git commit ..."
  echo ""
  echo "   (Aborting this commit so you can include the lockfile update explicitly.)"
  exit 1
fi

echo "[pre-commit] package-lock.json is in sync ✓"
