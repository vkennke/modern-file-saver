{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":semanticCommits",
        ":dependencyDashboard",
        ":maintainLockFilesWeekly"
    ],
    "timezone": "Europe/Berlin",
    "schedule": ["before 6am on monday"],
    "prHourlyLimit": 0,
    "prConcurrentLimit": 10,
    "rangeStrategy": "bump",
    "rebaseWhen": "behind-base-branch",
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": ["before 6am on monday"]
    },
    "packageRules": [
        {
            "description": "Group all non-major devDependency updates",
            "matchDepTypes": ["devDependencies"],
            "matchUpdateTypes": ["minor", "patch"],
            "groupName": "devDependencies (non-major)"
        },
        {
            "description": "Group all ESLint-related packages",
            "matchPackageNames": ["eslint", "/^@eslint//", "/^eslint-/", "typescript-eslint"],
            "groupName": "eslint"
        },
        {
            "description": "Group Vitest-related packages",
            "matchPackageNames": ["vitest", "/^@vitest//"],
            "groupName": "vitest"
        },
        {
            "description": "Group Changesets packages",
            "matchPackageNames": ["/^@changesets//"],
            "groupName": "changesets"
        },
        {
            "description": "Keep pnpm packageManager field up to date",
            "matchDepNames": ["pnpm"],
            "matchDepTypes": ["packageManager"],
            "rangeStrategy": "pin"
        },
        {
            "description": "Block TypeScript v6 until ecosystem (typescript-eslint, tsdown, ...) is ready",
            "matchPackageNames": ["typescript"],
            "matchUpdateTypes": ["major"],
            "enabled": false
        },
        {
            "description": "Don't narrow engines.node — keep the broad range we set intentionally for library consumers",
            "matchDepTypes": ["engines"],
            "matchPackageNames": ["node"],
            "enabled": false
        },
        {
            "description": "Don't pin Node to a patch version in GitHub Actions — stay on the major (e.g. 24) to always get latest security patches",
            "matchManagers": ["github-actions"],
            "matchPackageNames": ["node", "actions/node-versions"],
            "matchUpdateTypes": ["minor", "patch"],
            "enabled": false
        }
    ],
    "vulnerabilityAlerts": {
        "enabled": true,
        "labels": ["security"]
    },
    "github-actions": {
        "enabled": true
    }
}
