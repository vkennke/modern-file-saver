# Force pnpm to populate the lockfile with native binding optional
# dependencies for all CI-relevant platforms, regardless of which platform
# the developer is running. Without this, contributors on macOS would
# produce a lockfile missing the Linux bindings that CI needs (and vice
# versa), and `pnpm install --frozen-lockfile` in CI would fail.
#
# Covered targets: developer machines (macOS arm64/x64, Linux x64/arm64,
# Windows x64/arm64) and the GitHub Actions Ubuntu runner (linux/x64/glibc).
supportedArchitectures[os][]=darwin
supportedArchitectures[os][]=linux
supportedArchitectures[os][]=win32
supportedArchitectures[cpu][]=x64
supportedArchitectures[cpu][]=arm64
supportedArchitectures[libc][]=glibc
supportedArchitectures[libc][]=musl

# Surface peer-dependency issues early instead of silently auto-installing
# them (pnpm's default in v10+).
auto-install-peers=true

